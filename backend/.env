# Backend Environment Variables

# ── Database ──────────────────────────────────────────────────────────────────
# MySQL connection string — update user/password/host/port/dbname as needed
DATABASE_URL="mysql://root:Pa@24224365@localhost:3306/recipe_management"

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET="change-me-use-a-long-random-string-min-32-chars"
JWT_EXPIRES_IN="8h"
SALT_ROUNDS=12

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS="http://localhost:3000"

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_GENERAL=200
RATE_LIMIT_AUTH=20

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
