// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  OPS_MANAGER
  KITCHEN_MANAGER
  STORE_MANAGER
  APPROVER
}

enum RecipeStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum FoodType {
  VEG
  NON_VEG
  EGG
  VEGAN
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  BEVERAGE
  DESSERT
}

enum StepType {
  PREP
  COOK
  GARNISH
  HOLD
  PACK
}

enum AuditAction {
  CREATED
  UPDATED
  DELETED
  STATUS_CHANGED
  APPROVED
  REJECTED
  VERSION_CREATED
  INGREDIENT_ADDED
  INGREDIENT_REMOVED
  SUBMITTED_FOR_REVIEW
}

// ─────────────────────────────────────────────
// PORTAL: CLIENTS & COMPANIES (defined first for FK ordering)
// ─────────────────────────────────────────────

model Client {
  id           String   @id @default(uuid())
  name         String
  adminEmail   String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companies Company[]

  @@map("clients")
}

model Company {
  id        String   @id @default(uuid())
  name      String
  code      String
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("companies")
}

// ─────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Portal references (stored as plain strings, no FK constraint)
  clientId  String?
  companyId String?
  kitchenId String?

  createdRecipes  Recipe[]        @relation("RecipeCreator")
  approvedRecipes Recipe[]        @relation("RecipeApprover")
  recipeVersions  RecipeVersion[]
  auditLogs       AuditLog[]
  menuPlans       MenuPlan[]      @relation("MenuPlanCreator")

  @@map("users")
}

// ─────────────────────────────────────────────
// WAREHOUSE / KITCHEN
// ─────────────────────────────────────────────

model Warehouse {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipes         Recipe[]
  inventoryItems  InventoryItem[]
  menuPlans       MenuPlan[]

  @@map("warehouses")
}

// ─────────────────────────────────────────────
// INVENTORY ITEMS
// ─────────────────────────────────────────────

model InventoryItem {
  id           String  @id @default(uuid())
  itemCode     String  @unique
  itemName     String
  category     String
  unit         String
  currentStock Decimal @default(0) @db.Decimal(12, 3)
  minimumStock Decimal @default(0) @db.Decimal(12, 3)
  costPerUnit  Decimal @default(0) @db.Decimal(12, 4)
  isActive     Boolean @default(true)

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipeIngredients RecipeIngredient[]

  @@map("inventory_items")
}

// ─────────────────────────────────────────────
// RECIPES
// ─────────────────────────────────────────────

model Recipe {
  id               String       @id @default(uuid())
  recipeCode       String       @unique
  recipeName       String
  category         String
  mealType         MealType
  foodType         FoodType
  cuisineType      String?
  description      String?
  standardPax      Int
  yieldQty         Decimal      @db.Decimal(10, 3)
  yieldUnit        String
  portionPerPax    Decimal      @db.Decimal(10, 3)
  prepTimeMin      Int          @default(0)
  cookTimeMin      Int          @default(0)
  status           RecipeStatus @default(DRAFT)
  versionNumber    Int          @default(1)
  isCurrentVersion Boolean      @default(true)

  // Version tracking: null means this is the original recipe
  baseRecipeId String?
  baseRecipe   Recipe?  @relation("RecipeVersions", fields: [baseRecipeId], references: [id])
  versions     Recipe[] @relation("RecipeVersions")

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  createdBy   String
  creator     User    @relation("RecipeCreator", fields: [createdBy], references: [id])
  approvedBy  String?
  approver    User?   @relation("RecipeApprover", fields: [approvedBy], references: [id])
  approvedAt  DateTime?
  approvalNote String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete

  ingredients   RecipeIngredient[]
  steps         RecipeStep[]
  costs         RecipeCost[]
  tags          RecipeTag[]
  versionLogs   RecipeVersion[]
  menuPlanItems MenuPlanItem[]

  @@map("recipes")
}

// ─────────────────────────────────────────────
// RECIPE INGREDIENTS
// ─────────────────────────────────────────────

model RecipeIngredient {
  id              String @id @default(uuid())
  recipeId        String
  inventoryItemId String
  sequenceNo      Int    @default(0)

  grossQty        Decimal @db.Decimal(12, 4)
  grossUnit       String
  wastagePercent  Decimal @default(0) @db.Decimal(5, 2)
  netQty          Decimal @db.Decimal(12, 4)
  netUnit         String

  unitCostSnapshot Decimal @db.Decimal(12, 4)
  lineCost         Decimal @db.Decimal(12, 4)

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recipe        Recipe        @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@unique([recipeId, inventoryItemId])
  @@map("recipe_ingredients")
}

// ─────────────────────────────────────────────
// RECIPE STEPS
// ─────────────────────────────────────────────

model RecipeStep {
  id               String   @id @default(uuid())
  recipeId         String
  stepNo           Int
  stepType         StepType @default(PREP)
  instruction      String
  estimatedTimeMin Int      @default(0)
  equipmentName    String?
  temperatureNote  String?
  qcCheckNote      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("recipe_steps")
}

// ─────────────────────────────────────────────
// RECIPE COSTS
// ─────────────────────────────────────────────

model RecipeCost {
  id             String   @id @default(uuid())
  recipeId       String
  ingredientCost Decimal  @db.Decimal(12, 4)
  fuelCost       Decimal  @default(0) @db.Decimal(12, 4)
  laborCost      Decimal  @default(0) @db.Decimal(12, 4)
  packagingCost  Decimal  @default(0) @db.Decimal(12, 4)
  otherCost      Decimal  @default(0) @db.Decimal(12, 4)
  totalCost      Decimal  @db.Decimal(12, 4)
  costPerPax     Decimal  @db.Decimal(12, 4)
  calculatedAt   DateTime @default(now())

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("recipe_costs")
}

// ─────────────────────────────────────────────
// RECIPE VERSIONS
// ─────────────────────────────────────────────

model RecipeVersion {
  id            String   @id @default(uuid())
  recipeId      String
  baseRecipeId  String?
  versionNumber Int
  changeSummary String
  isCurrent     Boolean  @default(true)
  changedBy     String
  changedAt     DateTime @default(now())

  recipe  Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  changer User   @relation(fields: [changedBy], references: [id])

  @@map("recipe_versions")
}

// ─────────────────────────────────────────────
// RECIPE TAGS
// ─────────────────────────────────────────────

model RecipeTag {
  id       String @id @default(uuid())
  recipeId String
  tagName  String

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, tagName])
  @@map("recipe_tags")
}

// ─────────────────────────────────────────────
// MENU PLANS
// ─────────────────────────────────────────────

model MenuPlan {
  id          String   @id @default(uuid())
  planName    String
  planDate    DateTime @db.Date
  mealType    MealType
  description String?
  warehouseId String
  createdBy   String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  warehouse Warehouse      @relation(fields: [warehouseId], references: [id])
  creator   User           @relation("MenuPlanCreator", fields: [createdBy], references: [id])
  items     MenuPlanItem[]

  @@map("menu_plans")
}

model MenuPlanItem {
  id         String  @id @default(uuid())
  menuPlanId String
  recipeId   String
  servings   Int     @default(1)
  notes      String?
  sortOrder  Int     @default(0)

  menuPlan MenuPlan @relation(fields: [menuPlanId], references: [id], onDelete: Cascade)
  recipe   Recipe   @relation(fields: [recipeId], references: [id])

  @@unique([menuPlanId, recipeId])
  @@map("menu_plan_items")
}

// ─────────────────────────────────────────────
// AUDIT LOGS
// ─────────────────────────────────────────────

model AuditLog {
  id        String      @id @default(uuid())
  module    String
  entityId  String
  action    AuditAction
  oldValue  Json?
  newValue  Json?
  userId    String
  timestamp DateTime    @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
