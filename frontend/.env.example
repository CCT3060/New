# Frontend Environment Variables
# Copy this file to .env and fill in actual values

# ── API ───────────────────────────────────────────────────────────────────────
# Full URL to the backend API (used when not proxied)
VITE_API_BASE_URL=http://localhost:5000/api

# ── Dev Server ────────────────────────────────────────────────────────────────
# Port for the Vite dev server
VITE_PORT=3000
